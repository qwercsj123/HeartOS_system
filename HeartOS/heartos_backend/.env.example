APP_NAME=HeartOS Backend
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=9010
# Frontend page origins allowed by CORS. This must be the URL users open in the browser.
APP_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
APP_HTTP_TIMEOUT=45
APP_HTTP_RETRIES=2
APP_MAX_UPLOAD_MB=20
APP_UPLOAD_DIR=./data/uploads
# Public backend base URL used by frontend and generated links.
APP_PUBLIC_BASE_URL=http://127.0.0.1:9010
APP_ECGOMICS_URL=http://110.157.241.24:18023/ECGOmics
APP_AI_ECG_DIGITIZE_URL=http://219.147.100.43:18004/digitize
APP_CHEST_PAIN_PREDICT_URL=http://219.147.100.43:18020/predict_text
APP_LLM_DEFAULT_PROVIDER=zhipu
APP_LLM_DEFAULT_MODEL=glm-4-flash
APP_LLM_ZHIPU_API_KEY=
APP_LLM_OPENROUTER_API_KEY=
APP_LLM_DEEPSEEK_API_KEY=
APP_LLM_QWEN_API_KEY=
APP_LLM_GROQ_API_KEY=
APP_AUTH_SECRET=heartos-dev-secret-change-me
APP_AUTH_EXPIRE_HOURS=24
APP_USERS_FILE=./data/users.json
APP_DEFAULT_USERNAME=admin
APP_DEFAULT_PASSWORD=admin123

# 鉴权模式：local=使用本地 users.json；upstream=转发到外部账号服务
APP_AUTH_MODE=upstream
APP_AUTH_UPSTREAM_BASE=http://192.168.0.29:8081
APP_AUTH_UPSTREAM_LOGIN_PATH=/api/heartos/login
APP_AUTH_UPSTREAM_REGISTER_PATH=/api/heartos/register

# HandECG 数字化结果上传转发地址
APP_HANDECG_SAVE_URL=http://192.168.0.29:8081/api/heartos/saveHandECG
